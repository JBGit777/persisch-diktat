# Supabase – kopiere diese Datei zu .env.local und trage deine Werte ein.
# Die Werte findest du im Supabase-Dashboard unter:
#   Project Settings -> Data API  (Project URL)
#   Project Settings -> API Keys   (anon / publishable key)

NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=DEIN-ANON-PUBLIC-KEY

# Optional: für den "KI-Entwurf erzeugen"-Button bei der Grammatik.
# Key unter https://console.anthropic.com → API Keys erstellen.
# Ohne diesen Key ist der Button ausgeblendet; Grammatik kann man trotzdem
# selbst schreiben.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
